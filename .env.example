# ============================================
# AarogyaWhatsAI - Environment Variables
# ============================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/aarogya_whatsai?schema=public"

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-generate-with-openssl-rand-base64-32

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# WhatsApp Business Cloud API (Meta)
WHATSAPP_API_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
WHATSAPP_VERIFY_TOKEN=your-custom-webhook-verify-token
WHATSAPP_APP_SECRET=your-app-secret-for-signature-verification

# AI Provider (openai | anthropic | grok)
AI_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GROK_API_KEY=your-grok-api-key
GROK_BASE_URL=https://api.x.ai/v1

# Redis (for BullMQ job queue)
REDIS_URL=redis://localhost:6379

# File Storage (local or S3-compatible)
UPLOAD_DIR=./uploads
# AWS_S3_BUCKET=your-bucket
# AWS_S3_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
